@model SubscriptionFormViewModel

@{
    ViewData["Title"] = "Add Subscription";
}

<section class="page-heading">
    <div>
        <p class="section-eyebrow">New subscription</p>
        <h1>Add subscription</h1>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to list</a>
</section>

<form asp-action="Create" method="post" class="form-panel">
    <partial name="_Form" model="Model"/>
    <div class="form-footer">
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        <button type="submit" class="btn btn-primary">Create subscription</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
    <partial name="_TrialFieldsScript"/>
}
