@model SubscriptionFormViewModel

@{
    ViewData["Title"] = "Add Subscription";
}

<section class="subscription-form-page">
    <div class="subscription-form-heading">
        <div>
            <span>New subscription</span>
            <h1>Add subscription</h1>
            <p>Capture the billing details SubTrack needs for dashboards, renewals, and trial alerts.</p>
        </div>
        <a asp-action="Index" class="form-link-button">Back to list</a>
    </div>

    <form asp-action="Create" method="post" class="subscription-form-panel">
        <partial name="_Form" model="Model"/>
        <div class="subscription-form-footer">
            <a asp-action="Index" class="form-link-button">Cancel</a>
            <button type="submit" class="form-primary-button">Create subscription</button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
    <partial name="_TrialFieldsScript"/>
}
