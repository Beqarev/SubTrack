@model SubscriptionFormViewModel

@{
    ViewData["Title"] = "Edit Subscription";
}

<section class="page-heading">
    <div>
        <p class="section-eyebrow">Manage subscription</p>
        <h1>Edit @Model.Name</h1>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to list</a>
</section>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="form-panel">
    <input type="hidden" asp-for="Id"/>
    <partial name="_Form" model="Model"/>
    <div class="form-footer">
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        <button type="submit" class="btn btn-primary">Save changes</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
    <partial name="_TrialFieldsScript"/>
}
