@model SubscriptionFormViewModel

@{
    ViewData["Title"] = "Edit Subscription";
}

<section class="subscription-form-page">
    <div class="subscription-form-heading">
        <div>
            <span>Manage subscription</span>
            <h1>Edit @Model.Name</h1>
            <p>Update plan details, billing dates, status, and trial alert settings.</p>
        </div>
        <a asp-action="Index" class="form-link-button">Back to list</a>
    </div>

    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="subscription-form-panel">
        <input type="hidden" asp-for="Id"/>
        <partial name="_Form" model="Model"/>
        <div class="subscription-form-footer">
            <a asp-action="Index" class="form-link-button">Cancel</a>
            <button type="submit" class="form-primary-button">Save changes</button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
    <partial name="_TrialFieldsScript"/>
}
