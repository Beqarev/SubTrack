@model SubscriptionIndexViewModel

@{
    ViewData["Title"] = "Subscriptions";
}

<section class="page-heading">
    <div>
        <p class="section-eyebrow">Subscription Management</p>
        <h1>Subscriptions</h1>
    </div>
    <a asp-action="Create" class="btn btn-primary">Add subscription</a>
</section>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success" role="alert">@successMessage</div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-warning" role="alert">@errorMessage</div>
}

<section class="summary-grid" aria-label="Subscription summary">
    <div class="summary-card">
        <span>Total</span>
        <strong>@Model.TotalCount</strong>
    </div>
    <div class="summary-card">
        <span>Active monthly spend</span>
        <strong>@Model.ActiveMonthlySpend.ToString("C")</strong>
    </div>
    <div class="summary-card">
        <span>Filtered results</span>
        <strong>@Model.Subscriptions.Count</strong>
    </div>
</section>

<form asp-action="Index" method="get" class="filter-bar">
    <div>
        <label for="searchTerm" class="form-label">Search</label>
        <input id="searchTerm" name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Netflix, Adobe, storage"/>
    </div>
    <div>
        <label for="category" class="form-label">Category</label>
        <select id="category" name="category" asp-for="Category" asp-items="Html.GetEnumSelectList<SubscriptionCategory>()" class="form-select">
            <option value="">All categories</option>
        </select>
    </div>
    <div>
        <label for="status" class="form-label">Status</label>
        <select id="status" name="status" asp-for="Status" asp-items="Html.GetEnumSelectList<SubscriptionStatus>()" class="form-select">
            <option value="">All statuses</option>
        </select>
    </div>
    <div class="filter-actions">
        <button type="submit" class="btn btn-dark">Apply</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
    </div>
</form>

@if (Model.Subscriptions.Count == 0)
{
    <section class="empty-state">
        <h2>No subscriptions found</h2>
        <p>Add your first subscription or adjust the filters.</p>
        <a asp-action="Create" class="btn btn-primary">Add subscription</a>
    </section>
}
else
{
    <div class="table-responsive data-panel">
        <table class="table align-middle subscription-table">
            <thead>
            <tr>
                <th>Name</th>
                <th>Category</th>
                <th>Billing</th>
                <th>Next bill</th>
                <th>Status</th>
                <th>Trial</th>
                <th class="text-end">Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var subscription in Model.Subscriptions)
            {
                <tr>
                    <td>
                        <div class="fw-semibold">@subscription.Name</div>
                        <div class="text-muted small">@subscription.MonthlyCost.ToString("C") / month</div>
                    </td>
                    <td>@subscription.Category</td>
                    <td>
                        <div>@subscription.Price.ToString("0.00") @subscription.CurrencyCode</div>
                        <div class="text-muted small">@subscription.BillingCycle</div>
                    </td>
                    <td>
                        <div>@subscription.NextBillingDate.ToString("MMM d, yyyy")</div>
                        <div class="small @(subscription.IsBillDueSoon ? "text-danger fw-semibold" : "text-muted")">
                            @subscription.DaysUntilBilling days
                        </div>
                    </td>
                    <td>
                        <span class="badge rounded-pill @subscription.StatusBadgeCssClass">@subscription.Status</span>
                    </td>
                    <td>
                        @if (subscription.IsFreeTrial && subscription.TrialDaysRemaining is not null)
                        {
                            <span class="@(subscription.IsTrialExpiringSoon ? "text-danger fw-semibold" : "text-muted")">
                                @subscription.TrialDaysRemaining days left
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">None</span>
                        }
                    </td>
                    <td class="text-end">
                        <div class="action-row">
                            @if (subscription.Status != SubscriptionStatus.Canceled)
                            {
                                <form asp-action="ToggleStatus" asp-route-id="@subscription.Id" method="post">
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">
                                        @(subscription.Status == SubscriptionStatus.Active ? "Pause" : "Activate")
                                    </button>
                                </form>
                            }
                            <a asp-action="Edit" asp-route-id="@subscription.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@subscription.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
