@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    var isSignedIn = SignInManager.IsSignedIn(User);
    var userName = User.Identity?.Name ?? "Guest";
    var userInitial = string.IsNullOrWhiteSpace(userName) ? "S" : userName.Trim()[0].ToString().ToUpperInvariant();
}
<!DOCTYPE html>
<html lang="en" data-theme="midnight">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - SubTrack</title>
    <script>
        (function () {
            try {
                var theme = localStorage.getItem("subtrack-theme");
                if (theme === "midnight" || theme === "paper") {
                    document.documentElement.dataset.theme = theme;
                }
            } catch (_) {
                document.documentElement.dataset.theme = "midnight";
            }
        })();
    </script>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/subscriptions.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/analytics.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/alerts.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/settings.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/stage6-polish.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/SubTrack.styles.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/app-shell.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true"/>
</head>
<body>
@if (isSignedIn)
{
    <div class="app-shell">
        <aside class="sidebar" aria-label="Primary navigation">
            <a class="brand-lockup" asp-controller="Home" asp-action="Index">
                <span class="brand-mark">S</span>
                <span>
                    <span class="brand-title">SubTrack</span>
                    <span class="brand-subtitle">Smart Expenses</span>
                </span>
            </a>

            <nav class="sidebar-nav">
                <a class="sidebar-link @(controller == "Home" ? "active" : string.Empty)" asp-controller="Home" asp-action="Index">
                    <span class="nav-left"><span class="nav-icon">D</span> Dashboard</span>
                </a>
                <a class="sidebar-link @(controller == "Subscriptions" ? "active" : string.Empty)" asp-controller="Subscriptions" asp-action="Index">
                    <span class="nav-left"><span class="nav-icon">S</span> Subscriptions</span>
                </a>
                <a class="sidebar-link @(controller == "Analytics" ? "active" : string.Empty)" asp-controller="Analytics" asp-action="Index">
                    <span class="nav-left"><span class="nav-icon">A</span> Analytics</span>
                </a>
                <a class="sidebar-link @(controller == "Alerts" ? "active" : string.Empty)" asp-controller="Alerts" asp-action="Index">
                    <span class="nav-left"><span class="nav-icon">!</span> Alerts</span>
                    <span class="nav-badge">2</span>
                </a>
                <a class="sidebar-link @(controller == "Settings" ? "active" : string.Empty)" asp-controller="Settings" asp-action="Index">
                    <span class="nav-left"><span class="nav-icon">*</span> Settings</span>
                </a>
            </nav>

            <div class="sidebar-footer">
                <div class="trial-mini-card">
                    <span>Trial monitoring</span>
                    <strong>Free trial alerts</strong>
                    <em>Watch countdowns</em>
                </div>
                <div class="user-chip">
                    <span class="user-avatar">@userInitial</span>
                    <span>@userName</span>
                </div>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" class="sidebar-button">Logout</button>
                </form>
            </div>
        </aside>

        <main class="app-main">
            <div class="content-frame">
                @RenderBody()
            </div>
        </main>
    </div>
}
else
{
    <div class="public-shell">
        <header class="public-topbar">
            <a class="brand-lockup public-brand" asp-controller="Home" asp-action="Index">
                <span class="brand-mark">S</span>
                <span>
                    <span class="brand-title">SubTrack</span>
                    <span class="brand-subtitle">Smart Expenses</span>
                </span>
            </a>
            <nav class="public-nav" aria-label="Landing page sections">
                <a asp-controller="Home" asp-action="Index" asp-fragment="features">Features</a>
                <a asp-controller="Home" asp-action="Index" asp-fragment="how-it-works">How it works</a>
                <a asp-controller="Home" asp-action="Index" asp-fragment="faq">FAQ</a>
            </nav>
            <nav class="public-actions" aria-label="Account navigation">
                <a class="public-login @(controller == "Account" && action == "Login" ? "active" : string.Empty)" asp-controller="Account" asp-action="Login">Sign in</a>
                <a class="public-register @(controller == "Account" && action == "Register" ? "active" : string.Empty)" asp-controller="Account" asp-action="Register">Get started <span aria-hidden="true">-></span></a>
            </nav>
        </header>

        <main class="public-main">
            @RenderBody()
        </main>
    </div>
}

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
