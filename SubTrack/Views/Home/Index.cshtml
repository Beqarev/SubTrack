@model DashboardViewModel?

@{
    ViewData["Title"] = User.Identity?.IsAuthenticated == true ? "Overview" : "Home";
}

@if (User.Identity?.IsAuthenticated != true || Model is null)
{
    <section class="guest-panel dashboard-auth-card">
        <p class="section-eyebrow">Smart Subscription Management</p>
        <h1>Track recurring services, free trials, and monthly commitments.</h1>
        <p class="text-muted mb-0">
            Sign in to see your dark dashboard, manage subscriptions, and catch trial conversions before they charge.
        </p>
        <div class="guest-actions">
            <a asp-controller="Account" asp-action="Register" class="btn btn-primary">Create account</a>
            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary">Log in</a>
        </div>
    </section>
}
else
{
    var maxCategorySpend = Model.CategorySpending.Any()
        ? Model.CategorySpending.Max(category => category.MonthlySpend)
        : 0m;
    var topCategories = Model.CategorySpending.Take(5).ToList();
    var activeRows = Model.ActiveSubscriptions.Take(8).ToList();

    <section class="overview-header">
        <div>
            <h1>Overview</h1>
            <p>Track your monthly commitments and trials.</p>
        </div>
        <div class="dashboard-actions">
            <a asp-controller="Subscriptions" asp-action="Create" class="btn btn-primary">Add Subscription</a>
            @if (Model.ActiveSubscriptionCount == 0 && Model.PausedSubscriptionCount == 0)
            {
                <form asp-controller="Subscriptions" asp-action="SeedDemoData" method="post">
                    <button type="submit" class="btn btn-outline-secondary">Load demo data</button>
                </form>
            }
        </div>
    </section>

    <section class="overview-kpis" aria-label="Dashboard key metrics">
        <article class="overview-card kpi-card-v2">
            <span>Monthly spend</span>
            <strong>@Model.TotalMonthlySpend.ToString("C")</strong>
            <em class="positive">Active monthly total</em>
        </article>
        <article class="overview-card kpi-card-v2">
            <span>Projected annual</span>
            <strong>@Model.ProjectedAnnualSpend.ToString("C0")</strong>
            <em>Based on active plans</em>
        </article>
        <article class="overview-card kpi-card-v2">
            <span>Upcoming bills</span>
            <strong>@Model.UpcomingBillCount</strong>
            <em>Next 30 days</em>
        </article>
        <article class="overview-card kpi-card-v2 kpi-alert-card">
            <span>Trial alerts</span>
            <strong>@Model.TrialAlerts.Count</strong>
            <em class="warning">Needs attention</em>
        </article>
    </section>

    <section class="overview-grid">
        <article class="overview-card category-panel">
            <div class="panel-heading-v2">
                <h2>Spend by Category</h2>
                <span>Last 30 Days</span>
            </div>

            @if (topCategories.Count == 0)
            {
                <div class="dashboard-empty dark-empty">
                    <p>Add active subscriptions to see category spend breakdowns.</p>
                    <form asp-controller="Subscriptions" asp-action="SeedDemoData" method="post">
                        <button type="submit" class="btn btn-sm btn-outline-secondary">Load demo data</button>
                    </form>
                </div>
            }
            else
            {
                <div class="category-bars-v2">
                    @foreach (var category in topCategories)
                    {
                        var width = maxCategorySpend == 0 ? 0 : Math.Round(category.MonthlySpend / maxCategorySpend * 100m, 0);
                        <div class="category-row-v2">
                            <div class="category-meta-v2">
                                <span>@category.Category</span>
                                <strong>@category.MonthlySpend.ToString("C")</strong>
                            </div>
                            <div class="category-track-v2" aria-hidden="true">
                                <div class="category-fill-v2" style="width: @width%"></div>
                            </div>
                        </div>
                    }
                </div>
            }
        </article>

        <article class="overview-card smart-alerts-panel">
            <div class="panel-heading-v2">
                <h2>Smart Alerts</h2>
            </div>

            @if (Model.TrialAlerts.Count == 0)
            {
                <div class="dashboard-empty dark-empty">No active trial alerts right now.</div>
            }
            else
            {
                <div class="smart-alert-list">
                    @foreach (var trial in Model.TrialAlerts.Take(2))
                    {
                        <div class="smart-alert-card @(trial.IsUrgent ? "urgent" : string.Empty)">
                            <div>
                                <strong>@trial.SubscriptionName</strong>
                                <span>Converts on @trial.TrialEndDate.ToString("MMM d")</span>
                                <em>@trial.DaysRemaining day@(trial.DaysRemaining == 1 ? string.Empty : "s") left</em>
                            </div>
                            <a asp-controller="Subscriptions" asp-action="Edit" asp-route-id="@trial.SubscriptionId">View</a>
                        </div>
                    }
                </div>
            }
        </article>
    </section>

    <section class="overview-card active-table-panel">
        <div class="active-table-header">
            <h2>Active Subscriptions</h2>
            <div class="active-table-actions">
                <input class="dashboard-search" type="search" placeholder="Search..." disabled />
                <a asp-controller="Subscriptions" asp-action="Index" class="btn btn-sm btn-primary dashboard-view-all-btn">View all</a>
            </div>
        </div>

        @if (activeRows.Count == 0)
        {
            <div class="dashboard-empty dark-empty">
                <p>No active subscriptions yet.</p>
                <div class="empty-actions">
                    <a asp-controller="Subscriptions" asp-action="Create" class="btn btn-primary">Add subscription</a>
                    <form asp-controller="Subscriptions" asp-action="SeedDemoData" method="post">
                        <button type="submit" class="btn btn-outline-secondary">Load demo data</button>
                    </form>
                </div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table dashboard-table align-middle">
                    <thead>
                    <tr>
                        <th>Service</th>
                        <th>Category</th>
                        <th>Status</th>
                        <th>Cycle</th>
                        <th>Amount</th>
                        <th>Next bill</th>
                        <th class="text-end">Action</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var subscription in activeRows)
                    {
                        var initial = string.IsNullOrWhiteSpace(subscription.Name) ? "S" : subscription.Name.Trim()[0].ToString().ToUpperInvariant();
                        <tr>
                            <td>
                                <div class="service-cell">
                                    <span class="service-avatar">@initial</span>
                                    <span>
                                        <strong>@subscription.Name</strong>
                                        <em>@subscription.BillingCycle billing</em>
                                    </span>
                                </div>
                            </td>
                            <td>@subscription.Category</td>
                            <td><span class="status-pill active">Active</span></td>
                            <td>@subscription.BillingCycle</td>
                            <td><strong>@subscription.Price.ToString("C")</strong></td>
                            <td>@subscription.NextBillingDate.ToString("MMM d, yyyy")</td>
                            <td class="text-end">
                                <a asp-controller="Subscriptions" asp-action="Edit" asp-route-id="@subscription.Id" class="table-link">Edit</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </section>
}
