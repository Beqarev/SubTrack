@model RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<section class="auth-page">
    <div class="auth-card">
        <div class="auth-heading">
            <span>Start tracking</span>
            <h1>Create your SubTrack account</h1>
        </div>

        <form asp-action="Register" method="post" class="auth-form" novalidate>
            <div asp-validation-summary="ModelOnly" class="auth-validation-summary"></div>

            <label asp-for="FullName" class="auth-field">
                <span>Full name</span>
                <input asp-for="FullName" autocomplete="name"/>
                <small asp-validation-for="FullName"></small>
            </label>

            <label asp-for="Email" class="auth-field">
                <span>Email</span>
                <input asp-for="Email" autocomplete="email"/>
                <small asp-validation-for="Email"></small>
            </label>

            <label asp-for="Password" class="auth-field">
                <span>Password</span>
                <input asp-for="Password" autocomplete="new-password"/>
                <small asp-validation-for="Password"></small>
            </label>

            <label asp-for="ConfirmPassword" class="auth-field">
                <span>Confirm password</span>
                <input asp-for="ConfirmPassword" autocomplete="new-password"/>
                <small asp-validation-for="ConfirmPassword"></small>
            </label>

            <button type="submit" class="auth-submit">Create account</button>
        </form>

        <p class="auth-alt">
            Already have an account?
            <a asp-action="Login">Log in</a>
        </p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
