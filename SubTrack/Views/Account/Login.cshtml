@model LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<section class="auth-page">
    <div class="auth-card">
        <div class="auth-heading">
            <span>Welcome back</span>
            <h1>Log in to SubTrack</h1>
        </div>

        <form asp-action="Login" method="post" class="auth-form" novalidate>
            <input type="hidden" asp-for="ReturnUrl"/>
            <div asp-validation-summary="ModelOnly" class="auth-validation-summary"></div>

            <label asp-for="Email" class="auth-field">
                <span>Email</span>
                <input asp-for="Email" autocomplete="email"/>
                <small asp-validation-for="Email"></small>
            </label>

            <label asp-for="Password" class="auth-field">
                <span>Password</span>
                <input asp-for="Password" autocomplete="current-password"/>
                <small asp-validation-for="Password"></small>
            </label>

            <label class="auth-check">
                <input asp-for="RememberMe"/>
                <span>Remember me</span>
            </label>

            <button type="submit" class="auth-submit">Log in</button>
        </form>

        <p class="auth-alt">
            New to SubTrack?
            <a asp-action="Register">Create an account</a>
        </p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
